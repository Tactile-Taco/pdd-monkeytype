{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ErrorEnvelope",
  "type": "object",
  "required": [
    "error"
  ],
  "properties": {
    "error": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "enum": [
            "invalid_request",
            "unauthorized",
            "forbidden",
            "not_found",
            "conflict",
            "unprocessable",
            "rate_limited",
            "internal"
          ]
        },
        "message": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
