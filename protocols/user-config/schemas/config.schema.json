{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "mode": {
      "enum": [
        "time",
        "words",
        "quote",
        "zen",
        "custom"
      ]
    },
    "mode2": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "punctuation": {
      "type": "boolean"
    },
    "numbers": {
      "type": "boolean"
    },
    "difficulty": {
      "enum": [
        "normal",
        "expert",
        "master"
      ]
    },
    "blindMode": {
      "type": "boolean"
    },
    "stopOnError": {
      "enum": [
        "off",
        "letter",
        "word"
      ]
    },
    "theme": {
      "type": "string"
    },
    "lazyMode": {
      "type": "boolean"
    },
    "confidenceMode": {
      "type": "boolean"
    },
    "freedomMode": {
      "type": "boolean"
    },
    "strictSpace": {
      "type": "boolean"
    },
    "oppositeShift": {
      "type": "boolean"
    },
    "minWpm": {
      "type": "number",
      "minimum": 0
    },
    "minAcc": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "fontFamily": {
      "type": "string",
      "maxLength": 100
    },
    "fontSize": {
      "type": "number",
      "minimum": 0
    },
    "tapeMode": {
      "type": "boolean"
    },
    "quickRestart": {
      "enum": [
        "off",
        "tab",
        "esc",
        "enter"
      ]
    },
    "flipTestColors": {
      "type": "boolean"
    },
    "colorfulError": {
      "type": "boolean"
    },
    "customThemeId": {
      "type": "string",
      "maxLength": 100
    },
    "randomTheme": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
