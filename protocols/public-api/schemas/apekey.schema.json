{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApeKey (metadata shape; plaintext key material is NEVER in this shape)",
  "type": "object",
  "required": [
    "id",
    "name",
    "scopes",
    "createdAt",
    "enabled"
  ],
  "properties": {
    "id": {
      "type": "string",
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "results:read",
          "stats:read",
          "profile:read",
          "quotes:read"
        ]
      }
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0
    },
    "lastUsedAt": {
      "type": "integer",
      "minimum": 0
    },
    "enabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
