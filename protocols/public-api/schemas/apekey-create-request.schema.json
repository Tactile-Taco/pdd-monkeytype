{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApeKeyCreateRequest",
  "type": "object",
  "required": [
    "name",
    "scopes"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "results:read",
          "stats:read",
          "profile:read",
          "quotes:read"
        ]
      }
    }
  },
  "additionalProperties": false
}
