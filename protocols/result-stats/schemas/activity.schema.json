{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Activity series (UTC day buckets)",
  "type": "object",
  "required": [
    "days"
  ],
  "properties": {
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "testsCompleted",
          "timeTypingSeconds"
        ],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "testsCompleted": {
            "type": "integer",
            "minimum": 0
          },
          "timeTypingSeconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
