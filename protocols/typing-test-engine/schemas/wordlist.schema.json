{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "language",
    "words"
  ],
  "properties": {
    "id": {
      "type": "string",
      "maxLength": 100
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "words": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ordered": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
